<script define:vars={{ bento, ENCODED_EMAIL, SITE_DATA }}>window.__BENTO__ = bento; window.__EMAIL__ = ENCODED_EMAIL; window.__SITE__ = SITE_DATA;</script>
<script is:inline type="module">
    import { animate, inView, stagger, scroll } from "https://cdn.jsdelivr.net/npm/motion@10.18.0/+esm";

