            }
            if (!k) {
                const keys = Object.keys(SKILLS).filter((s) => s !== lastReveal);
                k = keys[Math.floor(Math.random() * keys.length)];
            }
            lastReveal = k;
            print('<b class="text-volt">' + k + '</b> <span class="text-void-500">[' + SKILLS[k].tag + ']</span> ' + esc(SKILLS[k].text));
