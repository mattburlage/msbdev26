    // Native scroll-behavior: smooth has a fixed (fast) browser duration, so anchor
    // clicks are animated by hand. Reduced motion keeps the CSS fallback (instant jump).
    if (!reduced) {
        const easeInOut = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
        document.querySelectorAll('a[href^="#"]:not([data-email])').forEach((a) => {
            a.addEventListener('click', (e) => {
