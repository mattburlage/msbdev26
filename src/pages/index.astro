    window.addEventListener('keydown', (e) => {
        if (e.key === '.' && !e.ctrlKey && !e.metaKey && !e.altKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
            body.classList.contains('ide-mode') ? exitIDE() : enterIDE();
            e.preventDefault();
        }
