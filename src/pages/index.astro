---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Resume from '../components/Resume.astro';
import Hero from '../components/home/Hero.astro';
import Experience from '../components/home/Experience.astro';
import Projects from '../components/home/Projects.astro';
import SkillsMarquee from '../components/home/SkillsMarquee.astro';
import Principles from '../components/home/Principles.astro';
import Contact from '../components/home/Contact.astro';
import Ide from '../components/ide/Ide.astro';
import { ENCODED_EMAIL } from '../data/identity';
import { bento } from '../data/builds';
import { resume } from '../data/resume';
import { SITE_DATA } from '../lib/ide-code';
---

<Layout>
<!-- ==================== NORMAL SITE ==================== -->
<div id="site" class="relative z-10">

    <!-- Dot field: fixed behind the whole site, not just the hero -->
    <div class="dot-grid" aria-hidden="true"></div>
    <canvas id="dot-canvas" class="dot-canvas" aria-hidden="true"></canvas>

    <Nav page="home" />

    <Hero />

    <main class="relative z-10">
        <Experience />
        <Projects />
        <SkillsMarquee />
        <Principles />
        <Contact />
    </main>

    <footer class="border-t border-void-800 relative z-10">
        <div class="max-w-6xl mx-auto px-5 py-8 flex flex-wrap items-center justify-between gap-3 font-mono text-xs text-void-400">
            <p>&copy; 2026 Matthew Smith Burlage</p>
            <button data-ide-open class="text-volt hover:underline cursor-pointer">$ enter dev mode</button>
        </div>
    </footer>
</div>

<Ide />

<!-- ==================== PRINT RESUME ==================== -->
<Resume resume={resume} />

<!-- Bootstrap: hands the shared server-side data to the client modules. Runs
     inline during parse, strictly before the deferred module bundle below. -->
<script is:inline define:vars={{ bento, ENCODED_EMAIL, SITE_DATA }}>window.__BENTO__ = bento; window.__EMAIL__ = ENCODED_EMAIL; window.__SITE__ = SITE_DATA;</script>
<script>
    import '../scripts/main';
</script>
<noscript set:html={`<style>.m-reveal { opacity: 1; } [data-ide-open] { display: none; }</style>`}></noscript>
</Layout>
