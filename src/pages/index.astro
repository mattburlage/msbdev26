---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';

// Latest blog posts, surfaced in the "How I build" section.
const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmtDate = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });

const isProd = import.meta.env.ENVIRONMENT === 'production';

// Email obfuscation - simple encoding to protect from scrapers
const EMAIL = 'hello@msb.dev';
const ENCODED_EMAIL = EMAIL.split('').map(c => c.charCodeAt(0)).join(',');

// Code-window contents are passed through set:html because they contain literal
// { } which Astro would otherwise parse as expressions. The class names still
// live in this file's source text, so Tailwind's content scanner picks them up.
const heroCode = `<span class="text-syn-kw">import</span> { msb } <span class="text-syn-kw">from</span> <span class="text-syn-str">"./career"</span>;

<span class="text-void-100">msb</span>.role;  <span class="text-syn-cm">// Senior Software Engineer</span>
<span class="text-void-100">msb</span>.since; <span class="text-syn-cm">// 2019</span>
<span class="text-void-100">msb</span>.frontend; <span class="text-syn-cm">// ["Vue", "React", "Angular"]</span>
<span class="text-void-100">msb</span>.backend; <span class="text-syn-cm">// ["Django", "WebSockets"]</span>
<span class="text-void-100">msb</span>.db; <span class="text-syn-cm">// ["PostgreSQL", "SQL Server", "Hasura"]</span>
<span class="text-void-100">msb</span>.contact(); <span class="text-syn-cm">// hello@msb.dev</span>`;

const experienceCode = `<span class="text-syn-cm">// experience.ts — reverse chronological</span>

<span class="text-syn-kw">export const</span> incyteStudios = {
  role: <span class="text-syn-str">"Senior Software Engineer"</span>,
  since: <span class="text-syn-num">2021</span>,
  highlights: [
    <span class="text-syn-str">"Go-to for novel, ambiguous problems on a mission-critical equipment-tracking system"</span>,
    <span class="text-syn-str">"Replaced legacy Django auth with Okta SSO for client logins"</span>,
    <span class="text-syn-str">"Integrated a client's Entra ID with Okta; server-to-server token negotiation"</span>,
    <span class="text-syn-str">"Solo-modernized a legacy technician-dispatch web & mobile app"</span>,
  ],
};

<span class="text-syn-kw">export const</span> hallCounty = {
  role: <span class="text-syn-str">"Senior Applications Developer"</span>,
  since: <span class="text-syn-num">2019</span>,
  highlights: [
    <span class="text-syn-str">"Founded and built the Enterprise Application Development division from the ground up"</span>,
    <span class="text-syn-str">"Led mission-critical systems across Agenda, Personnel, Fleet, Finance, Policies, and IT Access"</span>,
    <span class="text-syn-str">"Built a no-code CRUD platform, adopted across county departments"</span>,
    <span class="text-syn-str">"Deep Active Directory automation; owned the division's full SDLC"</span>,
    <span class="text-syn-str">"Mentored non-senior developers; owned sprints, timelines, and goals"</span>,
    <span class="text-syn-str">"Installed, configured, and managed CI/CD across dev, staging, and production"</span>,
  ],
};`;

const skillsCode = `{
  <span class="text-syn-fn">"frontend"</span>:  [<span class="text-syn-str">"Vue"</span>, <span class="text-syn-str">"React"</span>, <span class="text-syn-str">"Angular"</span>, <span class="text-syn-str">"Nuxt"</span>],
  <span class="text-syn-fn">"backend"</span>:   [<span class="text-syn-str">"Python"</span>, <span class="text-syn-str">"Django"</span>, <span class="text-syn-str">"WebSockets"</span>],
  <span class="text-syn-fn">"data"</span>:      [<span class="text-syn-str">"PostgreSQL"</span>, <span class="text-syn-str">"SQL Server"</span>, <span class="text-syn-str">"Hasura"</span>, <span class="text-syn-str">"Redis"</span>],
  <span class="text-syn-fn">"identity"</span>:  [<span class="text-syn-str">"Okta"</span>, <span class="text-syn-str">"Entra ID"</span>, <span class="text-syn-str">"Active Directory"</span>],
  <span class="text-syn-fn">"infra"</span>:     [<span class="text-syn-str">"Docker"</span>, <span class="text-syn-str">"Jenkins"</span>, <span class="text-syn-str">"GitHub Actions"</span>, <span class="text-syn-str">"Cloudflare"</span>],
  <span class="text-syn-fn">"cloud"</span>:     [<span class="text-syn-str">"DigitalOcean"</span>, <span class="text-syn-str">"GCP"</span>],
  <span class="text-syn-fn">"education"</span>: <span class="text-syn-str">"BS, Computer Science — University of North Georgia"</span>
}`;

// Single source of truth for "things I've built" — drives the hero bento cards
// (name + sub) and, next, Section 2 + the IDE projects pane (name + sub + content).
// type: 'system' | 'integration'. content is the longer description (to be filled in).
const builds = [
  { type: 'system', name: 'Position Control', sub: 'Employee Paperwork Automation', content: 'Budgeted positions, employee records, and labor-budget forecasting for HR and Finance.' },
  { type: 'system', name: 'IT Access Management', sub: 'Onboarding Automation w/ Active Directory', content: 'Automates employee access provisioning and onboarding through Active Directory.' },
  { type: 'system', name: 'Agenda Publishing', sub: 'Data collection, document creation and publishing', content: 'Meeting workflows for local governments: data collection, document generation, and publishing.' },
  { type: 'system', name: 'Technician Dispatch', sub: 'Safety and qualification management', content: 'A technician-dispatch platform across web and mobile that I solo-modernized, with safety and qualification checks before dispatch.' },
  { type: 'system', name: 'Service Orders & ERP', sub: 'Enterprise-scale order and asset tracking', content: 'Order and asset tracking built to handle enterprise volume.' },
  { type: 'system', name: 'Request for Proposals', sub: 'Handle requirements for public bids', content: 'Manages requirements and submissions for public procurement bids.' },
  { type: 'system', name: 'Video Production Suite', sub: 'Automated video editing and organization', content: 'Automates video editing and asset organization across the production pipeline.' },
  { type: 'system', name: 'Incident Management', sub: 'Maintain incident records and signatures', content: 'Maintains incident records and captures the sign-offs and signatures that go with them.' },
  { type: 'system', name: 'Time & Attendance', sub: 'Custom Attendance mechanism made simple', content: 'A custom time-and-attendance system that keeps tracking simple for staff.' },
  { type: 'system', name: 'Financial Records', sub: 'Recurring expenses, linked to each employee', content: 'Tracks recurring expenses and financial records linked to each employee.' },
  { type: 'system', name: 'Invoice Lifecycle Management', sub: 'Coordination between billing and ERP systems', content: 'Coordinates the invoice lifecycle between billing and ERP systems.' },
  { type: 'system', name: 'Contract Lifecycle Management', sub: 'Track contracts and renewals', content: 'Tracks contracts through their full lifecycle, including renewals.' },
  { type: 'integration', name: 'Okta integration', sub: 'Moved away from local auth to SSO', content: '' },
  { type: 'integration', name: 'Entra Server to Server', sub: 'Secure integration between systems', content: '' },
  { type: 'integration', name: 'Technician Risk Management', sub: 'Check Training system before dispatching', content: '' },
  { type: 'integration', name: 'Salesforce', sub: 'Massive integration of internal billing system', content: '' },
  { type: 'integration', name: 'Enterprise Resource Planning', sub: 'Track inventory and shipments across systems', content: '' },
  { type: 'integration', name: 'Video Post Production', sub: 'Automate graphics, footage organization', content: '' },
  { type: 'integration', name: 'Employee Onboarding', sub: 'Automatically create and provision new accounts', content: '' },
];

// Lightweight projection injected into the client-side bento script (name + sub only).
const bento = {
  all: builds.map((b) => ({ name: b.name, sub: b.sub })),
  systems: builds.filter((b) => b.type === 'system').map((b) => ({ name: b.name, sub: b.sub })),
  integrations: builds.filter((b) => b.type === 'integration').map((b) => ({ name: b.name, sub: b.sub })),
};
---

<Layout>
<!-- ==================== NORMAL SITE ==================== -->
<div id="site" class="relative z-10">

    <!-- Dot field: fixed behind the whole site, not just the hero -->
    <div class="dot-grid" aria-hidden="true"></div>
    <canvas id="dot-canvas" class="dot-canvas" aria-hidden="true"></canvas>

    <Nav page="home" />

    <!-- Hero -->
    <header id="top" class="relative z-10">
        <div class="max-w-6xl mx-auto px-5 pt-28 pb-12 sm:pt-40 sm:pb-16 relative">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
                <!-- Left column: text -->
                <div>
                    <p class="font-mono text-volt text-sm mb-6 m-reveal" data-hero>Hello World, I'm Matthew.</p>
                    <h1 class="text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tight text-void-100 leading-[0.95] m-reveal" data-hero>
                        <span id="scramble-1" data-text="SENIOR">SENIOR</span><br/>
                        <span id="scramble-2" data-text="SOFTWARE">SOFTWARE</span><br/>
                        <span class="text-volt" id="scramble-3" data-text="ENGINEER">ENGINEER</span>
                    </h1>
                    <p class="mt-4 text-3xl sm:text-4xl text-void-300 font-medium m-reveal" data-hero>Leader &amp; Systems Architect</p>
                    <div class="mt-8 m-reveal" data-hero>
                        <p class="max-w-md text-void-400 leading-relaxed mb-8">
                            I design, build, and scale secure, mission-critical software while mentoring those around me.
                        </p>
                        <div class="flex gap-4">
                            <a href="#contact" id="magnetic" class="inline-block px-6 py-3 bg-volt text-void-950 font-semibold rounded hover:bg-volt-dim transition-colors cursor-pointer will-change-transform">Get in touch</a>
                            <a href="#experience" class="inline-block px-6 py-3 border border-void-700 text-void-200 rounded hover:border-volt hover:text-void-100 transition-colors cursor-pointer">See the work</a>
                        </div>
                    </div>

                </div>

                <!-- Right column: code window + stats -->
                <div class="lg:mt-12 m-reveal sticky top-8" data-hero>
                    <!-- Teaser code window: the door to dev mode -->
                    <div class="border border-void-700 rounded-lg bg-void-900 overflow-hidden">
                        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-void-700">
                            <span class="w-2.5 h-2.5 rounded-full bg-void-500"></span>
                            <span class="w-2.5 h-2.5 rounded-full bg-void-500"></span>
                            <span class="w-2.5 h-2.5 rounded-full bg-void-500"></span>
                            <span class="ml-2 font-mono text-xs text-void-400">msb.ts</span>
                            <button data-ide-open class="ide-btn-gradient ml-auto flex items-center gap-1.5 px-2.5 py-1 rounded font-mono text-[11px] text-volt border border-void-700 hover:border-volt transition-colors cursor-pointer">
                                <svg width="9" height="9" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M4 2l10 6-10 6V2z"/></svg>
                                open in IDE
                            </button>
                        </div>
                        <pre class="p-8 font-mono text-sm sm:text-base leading-relaxed"><code set:html={heroCode}></code></pre>
                    </div>

                    <!-- Stats -->
                    <div class="mt-8 max-w-xl m-reveal" data-hero>
                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <p class="font-mono text-3xl sm:text-4xl font-semibold text-void-100"><span id="years-count">0</span><span class="text-volt">+</span></p>
                                <p class="text-xs font-mono text-void-400 mt-1">years</p>
                            </div>
                            <div>
                                <p class="font-mono text-3xl sm:text-4xl font-semibold text-void-100"><span data-count="12">0</span><span class="text-volt">+</span></p>
                                <p class="text-xs font-mono text-void-400 mt-1">production systems</p>
                            </div>
                            <div>
                                <p class="font-mono text-3xl sm:text-4xl font-semibold text-void-100"><span data-count="7">0</span><span class="text-volt">+</span></p>
                                <p class="text-xs font-mono text-void-400 mt-1">integrations shipped</p>
                            </div>
                        </div>
                        <!-- Bento Row (fading, single row) -->
                        <div id="bento-row" class="mt-4">
                            <div id="bento-row-content" class="grid grid-cols-3 gap-3 auto-rows-[168px]"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="relative z-10">

        <!-- Experience -->
        <section id="experience" class="border-t border-void-800">
            <div class="max-w-6xl mx-auto px-5 py-20 sm:py-28">
                <div class="flex items-baseline gap-6 mb-14">
                    <span class="sec-num m-reveal">01</span>
                    <h2 class="text-2xl sm:text-4xl font-bold text-void-100 m-reveal">Where I've been<span class="caret"></span></h2>
                </div>

                <div class="space-y-6" data-stagger>
                    <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 sm:p-8 m-reveal">
                        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
                            <h3 class="text-xl font-bold text-void-100">Incyte Studios</h3>
                            <span class="font-mono text-sm text-volt">Senior Software Engineer</span>
                            <span class="font-mono text-xs text-void-400 ml-auto">2021</span>
                        </div>
                        <ul class="mt-5 grid sm:grid-cols-2 gap-x-8 gap-y-3 text-sm text-void-200 leading-relaxed">
                            <li>The team's go-to for novel, ambiguous problems on a mission-critical equipment-tracking system for a Fortune 200 client.</li>
                            <li>Implemented Okta SSO end-to-end, replacing legacy local auth.</li>
                            <li>Integrated a client's Entra tenant with Okta for SSO.</li>
                            <li>Spearheaded a Salesforce integration with existing systems, including server-to-server Entra token negotiation.</li>
                            <li>Solo-modernized a legacy technician-dispatch web &amp; mobile app.</li>
                            <li>Built a driver-safety feature integrated with company-wide training tracking.</li>
                        </ul>
                    </div>

                    <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 sm:p-8 m-reveal">
                        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
                            <h3 class="text-xl font-bold text-void-100">Hall County Government</h3>
                            <span class="font-mono text-sm text-volt">Senior Applications Developer</span>
                            <span class="font-mono text-xs text-void-400 ml-auto">2019</span>
                        </div>
                        <ul class="mt-5 grid sm:grid-cols-2 gap-x-8 gap-y-3 text-sm text-void-200 leading-relaxed">
                            <li>Founded and built the Enterprise Application Development division from the ground up.</li>
                            <li>Led development of mission-critical systems across Agenda, Personnel, Fleet, Finance, Policies, and IT Access automation.</li>
                            <li>Built a no-code CRUD application platform, adopted for new apps across county departments.</li>
                            <li>Defined the division's full SDLC: tools, design paradigms, methodology, and stack.</li>
                            <li>Mentored non-senior developers; owned sprints, timelines, and goals.</li>
                            <li>Installed, configured, and managed CI/CD across dev, staging, and production.</li>
                        </ul>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" data-stagger>
                        <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                            <div class="flex flex-col gap-y-1">
                                <div class="flex items-baseline justify-between">
                                    <h3 class="text-lg font-bold text-void-100">Hall County Government</h3>
                                    <span class="font-mono text-xs text-void-400">2017</span>
                                </div>
                                <span class="font-mono text-xs text-volt">PC Technician</span>
                            </div>
                            <p class="mt-4 text-sm text-void-200 leading-relaxed">Handled hardware and software support for county systems.</p>
                        </div>

                        <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                            <div class="flex flex-col gap-y-1">
                                <div class="flex items-baseline justify-between">
                                    <h3 class="text-lg font-bold text-void-100">Geek Squad</h3>
                                    <span class="font-mono text-xs text-void-400">2013</span>
                                </div>
                                <span class="font-mono text-xs text-volt">Advanced Repair Agent</span>
                            </div>
                            <p class="mt-4 text-sm text-void-200 leading-relaxed">Repaired computers and consumer electronics.</p>
                        </div>

                        <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                            <div class="flex flex-col gap-y-1">
                                <div class="flex items-baseline justify-between">
                                    <h3 class="text-lg font-bold text-void-100">French Woods Festival</h3>
                                    <span class="font-mono text-xs text-void-400">2007</span>
                                </div>
                                <span class="font-mono text-xs text-volt">Stage Manager, Magic Department</span>
                            </div>
                            <p class="mt-4 text-sm text-void-200 leading-relaxed">Managed a theater, taught kids to cut each other in half.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Projects: bento grid -->
        <section id="projects" class="border-t border-void-800">
            <div class="max-w-6xl mx-auto px-5 py-20 sm:py-28">
                <div class="flex items-baseline gap-6 mb-14">
                    <span class="sec-num m-reveal">02</span>
                    <h2 class="text-2xl sm:text-4xl font-bold text-void-100 m-reveal">Things I've built<span class="caret"></span></h2>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>
                    {builds.filter((b) => b.type === 'system').map((b) => (
                        <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                            <h3 class="font-bold text-void-100">{b.name}</h3>
                            <p class="font-mono text-xs text-volt mt-1">{b.sub}</p>
                            {b.content && <p class="text-sm text-void-400 mt-3 leading-relaxed">{b.content}</p>}
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Skills marquee -->
        <section id="skills" class="border-t border-void-800 py-10">
            <div class="marquee" aria-label="Skills: Vue, React, Angular, Nuxt, TypeScript, Python, Django, WebSockets, Okta, Entra ID, Active Directory, PostgreSQL, SQL Server, Hasura, Redis, Docker, Jenkins, GitHub Actions, DigitalOcean, GCP, Cloudflare, Stripe">
                <div class="marquee-track font-mono text-sm" aria-hidden="true" id="marquee-track">
                    <!-- populated by JS (two copies for seamless loop) -->
                </div>
            </div>
            <p class="text-center mt-6 font-mono text-xs text-void-400">BS, Computer Science · University of North Georgia</p>
        </section>

        <!-- Principles -->
        <section id="principles" class="border-t border-void-800">
            <div class="max-w-6xl mx-auto px-5 py-20 sm:py-28">
                <div class="flex items-baseline gap-6 mb-4">
                    <span class="sec-num m-reveal">03</span>
                    <h2 class="text-2xl sm:text-4xl font-bold text-void-100 m-reveal">How I build<span class="caret"></span></h2>
                </div>
                <p class="font-mono text-volt text-sm mb-12 m-reveal">The hard part is the fun part.</p>

                <div class="grid gap-4 sm:grid-cols-2" data-stagger>
                    <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                        <p class="font-mono text-volt text-xs mb-3">[01]</p>
                        <h3 class="font-bold text-void-100 mb-2">Self-sufficient</h3>
                        <p class="text-sm text-void-400 leading-relaxed">I'm at my best taking on a task, understanding the why behind it along with the constraints and expectations, then executing.</p>
                    </div>
                    <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                        <p class="font-mono text-volt text-xs mb-3">[02]</p>
                        <h3 class="font-bold text-void-100 mb-2">Fast on the sure calls, consensus on the big ones</h3>
                        <p class="text-sm text-void-400 leading-relaxed">On familiar ground I decide quickly and move. When a call is high-stakes or genuinely ambiguous, I slow down on purpose and bring in the people it affects the most.</p>
                    </div>
                    <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                        <p class="font-mono text-volt text-xs mb-3">[03]</p>
                        <h3 class="font-bold text-void-100 mb-2">Collaboration where it counts</h3>
                        <p class="text-sm text-void-400 leading-relaxed">I reach for collaboration where it moves the work: code review, training, and untangling a genuinely hard problem together. Otherwise I'm heads-down and shipping.</p>
                    </div>
                    <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                        <p class="font-mono text-volt text-xs mb-3">[04]</p>
                        <h3 class="font-bold text-void-100 mb-2">Clear, then committed</h3>
                        <p class="text-sm text-void-400 leading-relaxed">I raise concerns and tradeoffs early, so calls get made with the full picture. Once we land on a direction, I follow through.</p>
                    </div>
                </div>

                {recentPosts.length > 0 && (
                    <div class="mt-16 m-reveal">
                        <div class="flex items-baseline justify-between mb-6">
                            <h3 class="font-mono text-xs text-void-400 uppercase tracking-widest">Recent writing</h3>
                            <a href="/blog" class="font-mono text-xs text-volt hover:underline cursor-pointer">all posts →</a>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            {recentPosts.map((post) => (
                                <a href={`/blog/${post.slug}`} class="spot block border border-void-700 rounded-xl bg-void-900 p-5 hover:border-volt/50 transition-colors">
                                    <time datetime={post.data.pubDate.toISOString()} class="font-mono text-xs text-void-400">{fmtDate(post.data.pubDate)}</time>
                                    <h4 class="font-bold text-void-100 mt-2 leading-snug">{post.data.title}</h4>
                                    <p class="text-sm text-void-400 mt-2 leading-relaxed">{post.data.description}</p>
                                </a>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </section>

        <!-- Contact -->
        <section id="contact" class="border-t border-void-800">
            <div class="max-w-6xl mx-auto px-5 py-24 sm:py-32 text-center">
                <p class="font-mono text-volt text-sm mb-4 m-reveal">so now what?</p>
                <h2 class="text-4xl sm:text-6xl font-bold text-void-100 tracking-tight m-reveal">Let's build something<br/><span class="text-volt">worth shipping.</span></h2>
                <p class="mt-6 text-void-400 max-w-md mx-auto m-reveal">If you think I can help your project or organization, reach out!</p>
                <div class="mt-10 flex flex-wrap justify-center gap-4 m-reveal">
                    <a href="#" data-email class="px-7 py-3.5 bg-volt text-void-950 font-semibold rounded hover:bg-volt-dim transition-colors cursor-pointer">hello@msb.dev</a>
                    <a href="https://github.com/mattburlage" target="_blank" rel="noopener" class="px-7 py-3.5 border border-void-700 text-void-200 rounded hover:border-volt/50 hover:text-void-100 transition-colors cursor-pointer">github.com/mattburlage</a>
                </div>
            </div>
        </section>

    </main>

    <footer class="border-t border-void-800 relative z-10">
        <div class="max-w-6xl mx-auto px-5 py-8 flex flex-wrap items-center justify-between gap-3 font-mono text-xs text-void-400">
            <p>&copy; 2026 Matthew Smith Burlage</p>
            <button data-ide-open class="text-volt hover:underline cursor-pointer">$ enter dev mode</button>
        </div>
    </footer>
</div>

<!-- ==================== IDE MODE ==================== -->
<div id="ide" class="font-mono text-sm bg-void-950 relative z-10" role="dialog" aria-modal="true" aria-label="Developer mode: IDE view of this site">
    <div class="h-full flex flex-col">

        <!-- Title bar -->
        <div class="ide-titlebar flex items-center gap-3 px-4 h-10 bg-void-900 border-b border-void-700 shrink-0">
            <div class="flex gap-1.5">
                <button data-ide-close class="w-3 h-3 rounded-full bg-[#ff5f57] hover:brightness-125 cursor-pointer" title="Exit dev mode" aria-label="Close dev mode"></button>
