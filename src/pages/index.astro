    }
    function hideEmptyState() {
        editorEmpty.classList.add('hidden');
        editorEmpty.classList.remove('flex');
        tumbleweedWrap.classList.add('hidden');
        tumbleweedWrap.classList.remove('rolling');
        clearTimeout(tumbleweedTimer);
