---
import { NAME, TITLE, SUBTITLE, TAGLINE, EMAIL_FALLBACK, EMPTY_STATE_TITLE } from '../../data/identity';
import { builds } from '../../data/builds';
import { principles, PRINCIPLES_TAGLINE } from '../../data/principles';
import { readmeStatsCode, experienceCode, skillsCode } from '../../lib/ide-code';
import { isProd } from '../../lib/env';
---

<!-- ==================== IDE MODE ==================== -->
<div id="ide" class="font-mono text-sm bg-void-950 relative z-10" role="dialog" aria-modal="true" aria-label="Developer mode: IDE view of this site">
    <div class="h-full flex flex-col">

        <!-- Title bar -->
        <div class="ide-titlebar flex items-center gap-3 px-4 h-10 bg-void-900 border-b border-void-700 shrink-0">
            <div class="flex gap-1.5">
                <button data-ide-close class="w-3 h-3 rounded-full bg-[#ff5f57] hover:brightness-125 cursor-pointer" title="Exit dev mode" aria-label="Close dev mode"></button>
                <button data-ide-close class="w-3 h-3 rounded-full bg-[#febc2e] hover:brightness-125 cursor-pointer" title="Exit dev mode" aria-label="Minimize dev mode"></button>
                <span class="w-3 h-3 rounded-full bg-[#28c840]" aria-hidden="true"></span>
            </div>
            <p class="flex-1 text-center text-xs text-void-400 truncate">
                {isProd ? NAME.toLowerCase() : <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-orange-500 text-void-950 font-semibold">{NAME.toLowerCase()}</span>}
            </p>
            <a href="#" data-email class="text-xs text-volt hover:underline cursor-pointer hidden sm:inline">{EMAIL_FALLBACK}</a>
        </div>

        <!-- Workbench -->
        <div class="flex-1 flex min-h-0">
            <aside id="ide-sidebar" class="ide-sidebar w-52 lg:w-60 bg-void-900 border-r border-void-700 shrink-0 hidden md:flex flex-col" aria-label="File explorer">
                <p class="px-4 pt-4 pb-2 text-[10px] tracking-widest text-void-400">EXPLORER</p>
                <p class="px-4 pb-1 text-xs text-void-400 flex items-center gap-1.5">
                    <svg width="10" height="10" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 4l4 4-4 4V4z" transform="rotate(90 8 8)"/></svg>
                    MATTHEW
                </p>
                <nav id="tree" class="flex-1 overflow-y-auto pb-4">
                    <button data-file="readme" class="tree-item w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <span class="text-syn-fn w-4 shrink-0 text-center">M↓</span><span class="tree-name">README.md</span>
                    </button>
                    <button data-file="experience" class="tree-item w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <span class="text-syn-fn w-4 shrink-0 text-center">TS</span><span class="tree-name">experience.ts</span>
                    </button>
                    <button data-file="projects" class="tree-item w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <span class="text-syn-fn w-4 shrink-0 text-center">M↓</span><span class="tree-name">projects.md</span>
                    </button>
                    <button data-file="skills" class="tree-item w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <span class="text-syn-num w-4 shrink-0 text-center">{'{}'}</span><span class="tree-name">skills.json</span>
                    </button>
                    <button id="folder-principles" aria-expanded="true" class="w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <svg id="folder-principles-chevron" class="transition-transform shrink-0 rotate-90" width="10" height="10" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M6 4l4 4-4 4V4z"/></svg>
                        <span class="tree-name">principles</span>
                    </button>
                    <div id="folder-principles-children">
                        {principles.map((p) => (
                            <button data-file={p.slug} class="tree-item w-full text-left pl-11 pr-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                                <span class="text-syn-fn w-4 shrink-0 text-center">M↓</span><span class="tree-name truncate">{p.slug}.md</span>
                            </button>
                        ))}
                    </div>
                    <button data-file="contact" class="tree-item w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <span class="text-volt w-4 shrink-0 text-center">$</span><span class="tree-name">contact.sh</span>
                    </button>
                    <button data-file="rendered" class="tree-item w-full text-left px-6 py-1.5 text-xs text-void-400 hover:bg-void-800 transition-colors cursor-pointer flex items-center gap-2">
                        <span class="text-syn-kw w-4 shrink-0 text-center text-[10px] tracking-tighter">&lt;/&gt;</span><span class="tree-name">index.html</span>
                    </button>
                </nav>
                <div class="px-4 py-3 border-t border-void-700 text-[10px] text-void-500 leading-relaxed">
                    <p>try <span class="text-volt">help</span> in the terminal below</p>
                    <p>type <span class="text-volt">exit</span> to return to the main site</p>
                </div>
            </aside>

            <div id="sidebar-resizer" class="hidden md:block w-1.5 shrink-0 cursor-col-resize touch-none hover:bg-syn-fn/25 transition-colors" role="separator" aria-orientation="vertical" aria-label="Resize file explorer" tabindex="0"></div>

            <div class="flex-1 flex flex-col min-w-0">
                <!-- Tabs are built at runtime (see ensureTab): README opens by default, everything else opens on demand and can be closed. -->
                <div id="tabs" class="flex bg-void-900 border-b border-void-700 overflow-x-auto shrink-0" role="tablist"></div>

                <!-- The editor viewport owns scrolling on both axes, so the horizontal
                     scrollbar pins to the bottom edge of the pane (like a real editor)
                     instead of floating under the last line of a wide code block. -->
                <div class="flex-1 overflow-auto min-h-0" id="editor">

                    <div id="editor-empty" class="hidden h-full flex-col items-center justify-center text-center px-6">
                        <p class="font-mono text-xs text-void-400">{EMPTY_STATE_TITLE}</p>
                        <p class="font-mono text-[11px] text-void-500 mt-1">pick one from the sidebar, or <span class="text-volt">ls()</span> below</p>
                        <div id="tumbleweed-wrap" class="hidden relative w-full max-w-lg h-44 mt-10 mx-auto overflow-hidden">
                            <div id="tumbleweed-mover" class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center">
                                <svg id="tumbleweed" class="text-void-500" width="116" height="116" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-linecap="round" aria-hidden="true">
                                    <path d="M86 50Q83 32 78.3 21.7Q68 14 50 16Q34 18 22.4 22.4Q15 35 13 50Q15 65 25.3 74.7Q36 86 50 91Q65 86 75.5 75.5Q84 65 86 50Z" stroke-width="1.5" opacity="0.55"/>
                                    <path d="M20 30L82 68M18 62L80 28M30 15L66 88M68 14L34 90M14 46L88 54M46 14L54 88" stroke-width="1" opacity="0.45"/>
                                    <circle cx="50" cy="50" r="13" opacity="0.3" stroke-width="1"/>
                                    <path d="M86 50l8-4M78.3 21.7l6-9M22.4 22.4l-7-10M13 50l-9 4M25.3 74.7l-8 9M75.5 75.5l7 10M50 16l0-10M50 91l0 8" stroke-width="1.3" opacity="0.5"/>
                                </svg>
                                <div class="tumbleweed-shadow -mt-1.5 h-3.5 w-24 rounded-full bg-void-950/70 blur-[2px]"></div>
                            </div>
                        </div>
                    </div>

                    <article id="pane-readme" class="file-pane active max-w-3xl px-6 sm:px-10 py-8 font-display">
                        <h1 class="text-3xl font-bold text-void-100">{NAME}</h1>
                        <p class="mt-1 text-volt font-mono text-sm">{TITLE}</p>
                        <p class="mt-1 text-void-300 font-medium">{SUBTITLE}</p>
                        <hr class="my-6 border-void-700"/>
                        <p class="leading-relaxed text-void-200">{TAGLINE}</p>
                        <pre class="mt-6 text-xs sm:text-sm leading-[1.8]"><code set:html={readmeStatsCode}></code></pre>
                        <div class="mt-8 flex flex-wrap gap-3 font-mono text-xs">
                            <button data-open="experience" class="px-4 py-2 bg-volt text-void-950 font-semibold rounded hover:bg-volt-dim transition-colors cursor-pointer">open experience.ts</button>
                            <button data-open="projects" class="px-4 py-2 border border-void-700 rounded hover:border-volt/50 transition-colors cursor-pointer">open projects.md</button>
                            <button data-open="contact" class="px-4 py-2 border border-void-700 rounded hover:border-volt/50 transition-colors cursor-pointer">open contact.sh</button>
                        </div>

                        <div class="mt-10 pt-8 border-t border-void-700">
                            <p class="font-mono text-[10px] tracking-widest text-void-500 uppercase mb-3">Using dev mode</p>
                            <ul class="space-y-2 text-sm text-void-400 leading-relaxed">
                                <li><span class="text-volt font-mono mr-2">→</span>click a file in the sidebar to open it — the <span class="text-void-200">×</span> on a tab closes it</li>
                                <li><span class="text-volt font-mono mr-2">→</span>the terminal is a real JS console — try <button data-run="help" class="text-volt font-mono hover:underline cursor-pointer">help</button></li>
                                <li><span class="text-volt font-mono mr-2">→</span>type <button data-run="exit" class="text-volt font-mono hover:underline cursor-pointer">exit</button>, press <kbd class="px-1.5 py-0.5 rounded border border-void-700 text-void-300 font-mono text-xs">Esc</kbd>, or click the red dot up top to leave</li>
                            </ul>
                        </div>
                    </article>

                    <div id="pane-experience" class="file-pane px-6 sm:px-10 py-8">
                        <pre class="text-xs sm:text-sm leading-[1.8]"><code set:html={experienceCode}></code></pre>
                        <p class="mt-6 text-xs text-syn-cm">// try <button data-run='msb.experience()' class="text-volt hover:underline cursor-pointer">msb.experience()</button> in the terminal below</p>
                    </div>

                    <article id="pane-projects" class="file-pane max-w-3xl px-6 sm:px-10 py-8 font-display">
                        <h1 class="text-2xl font-bold text-void-100 mb-6">Projects</h1>
                        <div class="space-y-6">
                            {builds.filter((b) => b.type === 'system').map((b) => (
                                <div class="border-l-2 border-void-700 pl-4">
                                    <h2 class="font-semibold text-void-100">{b.name} <span class="font-mono text-xs text-void-400 ml-1">{b.sub}</span></h2>
                                    {b.content && <p class="text-sm text-void-400 mt-1 leading-relaxed">{b.content}</p>}
                                </div>
                            ))}
                        </div>
                    </article>

                    <div id="pane-skills" class="file-pane px-6 sm:px-10 py-8">
                        <pre class="text-xs sm:text-sm leading-[1.8]"><code set:html={skillsCode}></code></pre>
                        <p class="mt-6 text-xs text-syn-cm">// deep-dive any of these: <button data-run='msb.reveal()' class="text-volt hover:underline cursor-pointer">msb.reveal()</button></p>
                    </div>

                    {principles.map((p, i) => (
                        <article id={`pane-${p.slug}`} class="file-pane max-w-3xl px-6 sm:px-10 py-8 font-display">
                            <p class="font-mono text-xs text-void-500 mb-6">// How I build · {PRINCIPLES_TAGLINE}</p>
                            <h1 class="text-2xl font-bold text-void-100"><span class="text-volt font-mono mr-2">{String(i + 1).padStart(2, '0')}.</span>{p.title}</h1>
                            <p class="mt-4 text-void-400 leading-relaxed">{p.text}</p>
                            <div class="mt-8 flex flex-wrap gap-3 font-mono text-xs">
                                {principles[i + 1] && <button data-open={principles[i + 1].slug} class="px-4 py-2 border border-void-700 rounded hover:border-volt/50 transition-colors cursor-pointer">next: {principles[i + 1].slug}.md →</button>}
                                {!principles[i + 1] && <button data-open={principles[0].slug} class="px-4 py-2 border border-void-700 rounded hover:border-volt/50 transition-colors cursor-pointer">back to: {principles[0].slug}.md</button>}
                            </div>
                        </article>
                    ))}

                    <div id="pane-contact" class="file-pane px-6 sm:px-10 py-8">
                        <pre class="text-xs sm:text-sm leading-[1.8]"><code><span class="text-syn-cm">#!/bin/sh</span>
<span class="text-syn-cm"># If you think I can help your project or organization, reach out!</span>

<span class="text-syn-fn">echo</span> <span class="text-syn-str">"email:  <span data-email-text>{EMAIL_FALLBACK}</span>"</span>
<span class="text-syn-fn">echo</span> <span class="text-syn-str">"github: github.com/mattburlage"</span>
<span class="text-syn-fn">echo</span> <span class="text-syn-str">"web:    www.msb.dev"</span></code></pre>
                        <div class="mt-8 flex flex-wrap gap-3 font-mono text-xs">
                            <a href="#" data-email class="px-4 py-2 bg-volt text-void-950 font-semibold rounded hover:bg-volt-dim transition-colors cursor-pointer">{EMAIL_FALLBACK}</a>
                            <a href="https://github.com/mattburlage" target="_blank" rel="noopener" class="px-4 py-2 border border-void-700 rounded hover:border-volt/50 transition-colors cursor-pointer">github.com/mattburlage</a>
                        </div>
                    </div>

                    <div id="pane-rendered" class="file-pane px-6 sm:px-10 py-8">
                        <pre class="text-xs sm:text-sm leading-[1.8]"><code id="rendered-html-code"></code></pre>
                    </div>

                </div>
            </div>
        </div>

        <!-- Terminal -->
        <div id="terminal-resizer" class="h-1.5 shrink-0 cursor-row-resize touch-none hover:bg-syn-fn/25 transition-colors" role="separator" aria-orientation="horizontal" aria-label="Resize terminal" tabindex="0"></div>
        <div id="ide-terminal" class="ide-terminal h-48 sm:h-52 bg-void-900 border-t border-void-700 shrink-0 flex flex-col">
            <div class="flex items-center gap-4 px-4 py-1.5 border-b border-void-700 text-[10px] tracking-widest text-void-400 shrink-0">
                <span class="text-void-200 border-b border-volt pb-1 -mb-[7px]">TERMINAL</span>
                <span class="ml-auto flex flex-wrap gap-1.5">
                    <button data-run="msb.reveal()" class="px-2 py-0.5 rounded border border-void-700 text-void-400 hover:text-volt hover:border-volt/40 transition-colors cursor-pointer normal-case tracking-normal font-mono">msb.reveal()</button>
                    <button data-run="ls()" class="px-2 py-0.5 rounded border border-void-700 text-void-400 hover:text-volt hover:border-volt/40 transition-colors cursor-pointer normal-case tracking-normal font-mono">ls()</button>
                    <button data-run="help" class="px-2 py-0.5 rounded border border-void-700 text-void-400 hover:text-volt hover:border-volt/40 transition-colors cursor-pointer normal-case tracking-normal font-mono">help</button>
                    <button data-run="exit" class="px-2 py-0.5 rounded border border-void-700 text-void-400 hover:text-volt hover:border-volt/40 transition-colors cursor-pointer normal-case tracking-normal font-mono">exit</button>
                </span>
            </div>
            <div id="repl-out" class="flex-1 overflow-y-auto px-4 py-2 text-xs leading-relaxed" aria-live="polite"></div>
            <div class="flex items-center gap-2 px-4 py-2 border-t border-void-700 shrink-0">
                <span class="text-xs text-volt select-none" aria-hidden="true">msb.dev &gt;</span>
                <input id="repl-in" type="text" autocomplete="off" spellcheck="false"
                    class="flex-1 bg-transparent text-xs text-void-100 placeholder-void-500 focus:outline-none"
                    placeholder='"help" for commands · "exit" to leave' aria-label="Interactive JavaScript console. Type help for commands, or exit to leave."/>
            </div>
        </div>

        <!-- Status bar -->
        <div class="flex items-center gap-4 px-4 h-6 bg-void-900 border-t border-void-700 text-[10px] text-void-400 shrink-0 overflow-x-auto">
            <span class="flex items-center gap-1 text-volt whitespace-nowrap">
                <svg width="10" height="10" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M11.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm-2.25.75a2.25 2.25 0 1 1 3 2.122V6A2.5 2.5 0 0 1 10 8.5H6a1 1 0 0 0-1 1v1.128a2.251 2.251 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.5 0v1.836A2.493 2.493 0 0 1 6 7h4a1 1 0 0 0 1-1v-.628A2.25 2.25 0 0 1 9.5 3.25Zm-6 0a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Zm.75 8.25a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Z"/></svg>
                main
            </span>
            <span id="status-file" class="whitespace-nowrap">README.md</span>
            <span class="ml-auto whitespace-nowrap">UTF-8</span>
            <span class="whitespace-nowrap">zero build step</span>
        </div>
    </div>
</div>

<style>
    /* void-400 (#7c7c94) is the shared "muted text" token used both in dev
       mode and on the main site. It read too dark against void-950 inside
       the IDE specifically, but the palette has no shade between void-400
       and void-200 (a much bigger jump), so scope a brighter in-between
       tone to #ide instead of touching the void-400 token everywhere. */
    #ide :global(.text-void-400) {
        color: #a3a3ba;
    }
    /* Same deal one tier down: void-500 (#3a3a4d) backs labels, terminal
       comments, and the console placeholder. Brighten it too, but keep it
       dimmer than the void-400 override above so the two tiers still read
       as distinct levels of emphasis. */
    #ide :global(.text-void-500) {
        color: #626278;
    }
    #ide :global(.placeholder-void-500)::placeholder {
        color: #626278;
    }
</style>
