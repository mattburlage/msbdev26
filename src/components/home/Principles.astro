---
import { getCollection } from 'astro:content';
import { principles, PRINCIPLES_TAGLINE } from '../../data/principles';
import { showWriting } from '../../lib/env';

// Latest blog posts, surfaced under the principle cards.
const recentPosts = showWriting
  ? (await getCollection('blog'))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3)
  : [];
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<!-- Principles -->
<section id="principles" class="relative overflow-hidden">
    <div id="principles-wireframe" aria-hidden="true">
        <svg viewBox="0 0 320 420" fill="none" stroke="currentColor" stroke-width="0.9" preserveAspectRatio="xMidYMid meet">
            <!-- Outer frame -->
            <rect x="10" y="10" width="300" height="400" />
            <rect x="20" y="20" width="280" height="380" opacity="0.6" />

            <!-- Grid -->
            <g opacity="0.25">
                <line x1="10" y1="60" x2="310" y2="60" />
                <line x1="10" y1="110" x2="310" y2="110" />
                <line x1="10" y1="160" x2="310" y2="160" />
                <line x1="10" y1="210" x2="310" y2="210" />
                <line x1="10" y1="260" x2="310" y2="260" />
                <line x1="10" y1="310" x2="310" y2="310" />
                <line x1="10" y1="360" x2="310" y2="360" />
                <line x1="60" y1="10" x2="60" y2="410" />
                <line x1="110" y1="10" x2="110" y2="410" />
                <line x1="160" y1="10" x2="160" y2="410" />
                <line x1="210" y1="10" x2="210" y2="410" />
                <line x1="260" y1="10" x2="260" y2="410" />
            </g>

            <!-- Main assembly: bracket shape -->
            <path d="M80 140 L80 80 L240 80 L240 140 L200 140 L200 240 L240 240 L240 300 L80 300 L80 240 L120 240 L120 140 Z" />

            <!-- Center feature -->
            <circle cx="160" cy="190" r="35" />
            <circle cx="160" cy="190" r="22" />
            <circle cx="160" cy="190" r="8" fill="currentColor" fill-opacity="0.2" />
            <line x1="160" y1="120" x2="160" y2="260" stroke-dasharray="4 4" />
            <line x1="120" y1="190" x2="200" y2="190" stroke-dasharray="4 4" />

            <!-- Bolt holes -->
            <circle cx="100" cy="100" r="5" />
            <circle cx="220" cy="100" r="5" />
            <circle cx="100" cy="280" r="5" />
            <circle cx="220" cy="280" r="5" />

            <!-- Right-side detail view -->
            <rect x="245" y="130" width="45" height="45" />
            <circle cx="267.5" cy="152.5" r="12" />
            <line x1="267.5" y1="130" x2="267.5" y2="175" stroke-dasharray="3 3" />
            <line x1="245" y1="152.5" x2="290" y2="152.5" stroke-dasharray="3 3" />

            <!-- Dimension lines -->
            <g opacity="0.7">
                <line x1="80" y1="50" x2="240" y2="50" />
                <line x1="80" y1="45" x2="80" y2="55" />
                <line x1="240" y1="45" x2="240" y2="55" />
                <path d="M155 50 L160 45 L165 50" />
                <path d="M155 50 L160 55 L165 50" />

                <line x1="280" y1="80" x2="280" y2="300" />
                <line x1="275" y1="80" x2="285" y2="80" />
                <line x1="275" y1="300" x2="285" y2="300" />
                <path d="M280 185 L275 190 L280 195" />
                <path d="M280 185 L285 190 L280 195" />
            </g>

            <!-- Construction arcs -->
            <path d="M160 190 L120 150 A56 56 0 0 1 200 150 Z" opacity="0.4" />
            <path d="M160 190 L120 230 A56 56 0 0 0 200 230 Z" opacity="0.4" />

            <!-- Corner brackets -->
            <path d="M30 30 L30 45 M30 30 L45 30" />
            <path d="M290 30 L290 45 M290 30 L275 30" />
            <path d="M30 390 L30 375 M30 390 L45 390" />
            <path d="M290 390 L290 375 M290 390 L275 390" />

            <!-- Section hatch -->
            <g opacity="0.15" stroke-width="0.6">
                <line x1="100" y1="155" x2="140" y2="195" />
                <line x1="110" y1="145" x2="150" y2="185" />
                <line x1="120" y1="135" x2="160" y2="175" />
            </g>
        </svg>
    </div>
    <div class="max-w-6xl mx-auto px-5 py-20 sm:py-28">
        <div class="flex items-baseline gap-6 mb-4">
            <span class="sec-num m-reveal">03</span>
            <h2 class="text-2xl sm:text-4xl font-bold text-void-100 m-reveal">How I build<span class="caret"></span></h2>
        </div>
        <p class="font-mono text-volt text-sm mb-12 m-reveal">{PRINCIPLES_TAGLINE}</p>

        <div class="grid gap-4 sm:grid-cols-2" data-stagger>
            {principles.map((p, i) => (
                <div class="spot border border-void-700 rounded-xl bg-void-900 p-6 m-reveal">
                    <p class="font-mono text-volt text-xs mb-3">[{String(i + 1).padStart(2, '0')}]</p>
                    <h3 class="font-bold text-void-100 mb-2">{p.title}</h3>
                    <p class="text-sm text-void-400 leading-relaxed">{p.text}</p>
                </div>
            ))}
        </div>

        {recentPosts.length > 0 && (
            <div class="mt-16 m-reveal">
                <div class="flex items-baseline justify-between mb-6">
                    <h3 class="font-mono text-xs text-void-400 uppercase tracking-widest">Recent writing</h3>
                    <a href="/blog" class="font-mono text-xs text-volt hover:underline cursor-pointer">all posts →</a>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    {recentPosts.map((post) => (
                        <a href={`/blog/${post.id}`} class="spot block border border-void-700 rounded-xl bg-void-900 p-5 hover:border-volt/50 transition-colors">
                            <time datetime={post.data.pubDate.toISOString()} class="font-mono text-xs text-void-400">{fmtDate(post.data.pubDate)}</time>
                            <h4 class="font-bold text-void-100 mt-2 leading-snug">{post.data.title}</h4>
                            <p class="text-sm text-void-400 mt-2 leading-relaxed">{post.data.description}</p>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>
</section>
